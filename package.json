{
  "name": "the-amy-shop",
  "version": "0.0.0",
  "private": true,
  "description": "Professional PERN stack e-commerce platform for a handmade custom gift shop.",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm run client:dev\" \"npm run server:dev\"",
    "client:dev": "npm --prefix client run dev",
    "server:dev": "npm --prefix server run dev",
    "client:build": "npm --prefix client run build",
    "server:build": "npm --prefix server run build",
    "build": "npm run client:build && npm run server:build",
    "server:prisma:generate": "npm --prefix server run prisma:generate",
    "server:prisma:migrate": "npm --prefix server run prisma:migrate",
    "server:prisma:studio": "npm --prefix server run prisma:studio",
    "client:lint": "npm --prefix client run lint",
    "client:preview": "npm --prefix client run preview",
    "server:start": "npm --prefix server run start"
  },
  "keywords": [
    "pern",
    "ecommerce",
    "react",
    "express",
    "postgresql",
    "prisma"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
