// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum StockType {
  READY_STOCK
  MADE_TO_ORDER
  PRE_ORDER
  OUT_OF_STOCK
}

enum PaymentMethod {
  KHALTI
  ESEWA
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  IN_PRODUCTION
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum GiftPrintStatus {
  PENDING
  PRINTED
  ATTACHED
}

enum CustomizationStatus {
  PENDING_REVIEW
  APPROVED
  NEEDS_CLARIFICATION
  IN_PRODUCTION
  COMPLETED
  REJECTED
}

enum CouponType {
  PERCENTAGE_DISCOUNT
  FIXED_DISCOUNT
  FREE_SHIPPING
  FREE_GIFT_WRAP
}

enum RewardTransactionType {
  PURCHASE_REWARD
  FIRST_PURCHASE_BONUS
  REFERRAL_REWARD
  REVIEW_REWARD
  REDEEMED
  EXPIRED
  REFUNDED
  ADMIN_ADJUSTMENT
}

enum ReferralStatus {
  REGISTERED
  FIRST_ORDER_PLACED
  QUALIFIED
  REWARDED
  CANCELLED
}

enum ReviewStatus {
  PENDING
  APPROVED
  HIDDEN
  DELETED
}

model User {
  id                   String                 @id @default(cuid())
  fullName             String
  email                String?                @unique
  phone                String                 @unique
  passwordHash         String
  role                 UserRole               @default(CUSTOMER)
  status               AccountStatus          @default(ACTIVE)
  emailVerified        Boolean                @default(false)
  phoneVerified        Boolean                @default(false)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  addresses            Address[]
  cart                 Cart?
  couponRedemptions    CouponRedemption[]
  customizations       CustomizationRequest[]
  orders               Order[]
  profile              CustomerProfile?
  referralCode         ReferralCode?
  referralsMade        Referral[]             @relation("Referrer")
  referralReceived     Referral?              @relation("ReferredUser")
  reviews              Review[]
  rewardTransactions   RewardTransaction[]
  rewardWallet         RewardWallet?
  changedOrderStatuses OrderStatusHistory[]   @relation("OrderStatusChangedBy")

  @@index([phone])
  @@index([email])
  @@map("users")
}

model CustomerProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  profileImage String?
  totalOrders  Int      @default(0)
  totalSpent   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

model Address {
  id            String   @id @default(cuid())
  userId        String
  fullName      String
  phone         String
  province      String
  district      String
  city          String
  streetAddress String
  landmark      String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([slug])
  @@index([isActive])
  @@map("categories")
}

model Product {
  id               String                 @id @default(cuid())
  categoryId       String
  name             String
  slug             String                 @unique
  shortDescription String?
  description      String
  productStory     String?
  material         String?
  careInstructions String?
  makingTime       String?
  price            Decimal                @db.Decimal(10, 2)
  compareAtPrice   Decimal?               @db.Decimal(10, 2)
  stock            Int                    @default(0)
  stockType        StockType              @default(READY_STOCK)
  isCustomizable   Boolean                @default(false)
  isGiftSupported  Boolean                @default(false)
  isActive         Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  cartItems        CartItem[]
  category         Category               @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  customizations   CustomizationRequest[]
  images           ProductImage[]
  orderItems       OrderItem[]
  reviews          Review[]

  @@index([slug])
  @@index([categoryId])
  @@index([isActive])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  imageUrl  String
  publicId  String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  sessionId String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("carts")
}

model CartItem {
  id                     String                @id @default(cuid())
  cartId                 String
  productId              String
  customizationRequestId String?
  quantity               Int
  priceSnapshot          Decimal               @db.Decimal(10, 2)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  cart                   Cart                  @relation(fields: [cartId], references: [id], onDelete: Cascade)
  customizationRequest   CustomizationRequest? @relation(fields: [customizationRequestId], references: [id], onDelete: SetNull)
  product                Product               @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([cartId])
  @@index([productId])
  @@index([customizationRequestId])
  @@map("cart_items")
}

model Order {
  id                  String               @id @default(cuid())
  userId              String
  addressId           String
  orderNumber         String               @unique
  subtotal            Decimal              @default(0) @db.Decimal(12, 2)
  couponDiscount      Decimal              @default(0) @db.Decimal(12, 2)
  gemsDiscount        Decimal              @default(0) @db.Decimal(12, 2)
  customizationFee    Decimal              @default(0) @db.Decimal(12, 2)
  giftWrapFee         Decimal              @default(0) @db.Decimal(12, 2)
  shippingFee         Decimal              @default(0) @db.Decimal(12, 2)
  totalAmount         Decimal              @db.Decimal(12, 2)
  paymentMethod       PaymentMethod
  paymentStatus       PaymentStatus        @default(PENDING)
  orderStatus         OrderStatus          @default(PENDING)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  address             Address              @relation(fields: [addressId], references: [id], onDelete: Restrict)
  couponRedemptions   CouponRedemption[]
  giftOption          GiftOption?
  items               OrderItem[]
  payment             Payment?
  rewardTransactions  RewardTransaction[]
  statusHistory       OrderStatusHistory[]
  user                User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  qualifyingReferrals Referral[]           @relation("QualifyingOrder")
  reviews             Review[]

  @@index([userId])
  @@index([addressId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id                     String                @id @default(cuid())
  orderId                String
  productId              String
  customizationRequestId String?
  productNameSnapshot    String
  priceSnapshot          Decimal               @db.Decimal(10, 2)
  quantity               Int
  createdAt              DateTime              @default(now())
  customizationRequest   CustomizationRequest? @relation(fields: [customizationRequestId], references: [id], onDelete: SetNull)
  order                  Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product                Product               @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@index([customizationRequestId])
  @@map("order_items")
}

model Payment {
  id                    String        @id @default(cuid())
  orderId               String        @unique
  provider              PaymentMethod
  providerTransactionId String?
  amount                Decimal       @db.Decimal(12, 2)
  status                PaymentStatus @default(PENDING)
  rawResponse           Json          @default("{}")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  order                 Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([providerTransactionId])
  @@index([status])
  @@map("payments")
}

model GiftOption {
  id               String          @id @default(cuid())
  orderId          String          @unique
  receiverName     String
  senderName       String
  giftMessage      String
  giftWrapRequired Boolean         @default(false)
  giftWrapFee      Decimal         @default(0) @db.Decimal(10, 2)
  printStatus      GiftPrintStatus @default(PENDING)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("gift_options")
}

model CustomizationRequest {
  id               String                        @id @default(cuid())
  userId           String
  productId        String
  customText       String?
  colorPreference  String?
  sizePreference   String?
  designNote       String?
  neededByDate     DateTime?
  customizationFee Decimal                       @default(0) @db.Decimal(10, 2)
  status           CustomizationStatus           @default(PENDING_REVIEW)
  adminNote        String?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt
  cartItems        CartItem[]
  orderItems       OrderItem[]
  product          Product                       @relation(fields: [productId], references: [id], onDelete: Restrict)
  referenceImages  CustomizationReferenceImage[]
  user             User                          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
  @@index([status])
  @@map("customization_requests")
}

model CustomizationReferenceImage {
  id                     String               @id @default(cuid())
  customizationRequestId String
  imageUrl               String
  publicId               String
  createdAt              DateTime             @default(now())
  customizationRequest   CustomizationRequest @relation(fields: [customizationRequestId], references: [id], onDelete: Cascade)

  @@index([customizationRequestId])
  @@map("customization_reference_images")
}

model Coupon {
  id                    String             @id @default(cuid())
  code                  String             @unique
  title                 String
  description           String?
  discountType          CouponType
  discountValue         Decimal            @default(0) @db.Decimal(10, 2)
  minimumOrderAmount    Decimal            @default(0) @db.Decimal(12, 2)
  maximumDiscountAmount Decimal?           @db.Decimal(12, 2)
  usageLimit            Int?
  usedCount             Int                @default(0)
  perUserLimit          Int                @default(1)
  startsAt              DateTime
  expiresAt             DateTime
  isActive              Boolean            @default(true)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  redemptions           CouponRedemption[]

  @@index([code])
  @@index([isActive])
  @@index([startsAt])
  @@index([expiresAt])
  @@map("coupons")
}

model CouponRedemption {
  id             String   @id @default(cuid())
  couponId       String
  userId         String
  orderId        String
  discountAmount Decimal  @db.Decimal(12, 2)
  usedAt         DateTime @default(now())
  coupon         Coupon   @relation(fields: [couponId], references: [id], onDelete: Restrict)
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, orderId])
  @@index([couponId])
  @@index([userId])
  @@index([orderId])
  @@map("coupon_redemptions")
}

model RewardWallet {
  id             String   @id @default(cuid())
  userId         String   @unique
  balance        Int      @default(0)
  lifetimeEarned Int      @default(0)
  lifetimeSpent  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reward_wallets")
}

model RewardTransaction {
  id          String                @id @default(cuid())
  userId      String
  orderId     String?
  type        RewardTransactionType
  gems        Int
  description String
  expiresAt   DateTime?
  createdAt   DateTime              @default(now())
  order       Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orderId])
  @@index([type])
  @@map("reward_transactions")
}

model ReferralCode {
  id                  String     @id @default(cuid())
  userId              String     @unique
  code                String     @unique
  totalReferrals      Int        @default(0)
  successfulReferrals Int        @default(0)
  isActive            Boolean    @default(true)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  referrals           Referral[]
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@map("referral_codes")
}

model Referral {
  id                String         @id @default(cuid())
  referrerUserId    String
  referredUserId    String         @unique
  referralCodeId    String
  status            ReferralStatus @default(REGISTERED)
  rewardGiven       Boolean        @default(false)
  qualifyingOrderId String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  qualifyingOrder   Order?         @relation("QualifyingOrder", fields: [qualifyingOrderId], references: [id], onDelete: SetNull)
  referralCode      ReferralCode   @relation(fields: [referralCodeId], references: [id], onDelete: Restrict)
  referredUser      User           @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  referrerUser      User           @relation("Referrer", fields: [referrerUserId], references: [id], onDelete: Cascade)

  @@index([referrerUserId])
  @@index([referredUserId])
  @@index([referralCodeId])
  @@index([status])
  @@map("referrals")
}

model Review {
  id        String       @id @default(cuid())
  userId    String
  productId String
  orderId   String
  rating    Int
  comment   String?
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, orderId])
  @@index([productId])
  @@index([userId])
  @@index([status])
  @@map("reviews")
}

model OrderStatusHistory {
  id              String       @id @default(cuid())
  orderId         String
  oldStatus       OrderStatus?
  newStatus       OrderStatus
  changedByUserId String?
  note            String?
  createdAt       DateTime     @default(now())
  changedBy       User?        @relation("OrderStatusChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)
  order           Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([changedByUserId])
  @@index([newStatus])
  @@map("order_status_histories")
}
