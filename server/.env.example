NODE_ENV=development
PORT=5000

# PostgreSQL / Supabase connection string. Replace every placeholder locally.
DATABASE_URL=postgresql://DATABASE_USER:DATABASE_PASSWORD@DATABASE_HOST:5432/DATABASE_NAME?schema=public

# Browser application URLs. Separate multiple trusted CORS origins with commas.
# If Vite selects another port, add both localhost and 127.0.0.1 forms for that port.
# In production, list only deployed/trusted frontend origins. Never use a wildcard.
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Use long, unique random values. Never reuse these placeholders in production.
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-secret

# Cloudinary product image uploads.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_PRODUCT_FOLDER=the-amy-shop/products

# Online-payment provider placeholders. COD is the only active storefront method.
KHALTI_SECRET_KEY=your-khalti-secret-key
KHALTI_PUBLIC_KEY=your-khalti-public-key
KHALTI_BASE_URL=https://example-khalti-provider.test
ESEWA_MERCHANT_CODE=your-esewa-merchant-code
ESEWA_SECRET_KEY=your-esewa-secret-key
ESEWA_BASE_URL=https://example-esewa-provider.test
PAYMENT_SUCCESS_URL=http://localhost:5173/payment/success
PAYMENT_FAILURE_URL=http://localhost:5173/payment/failure
